  "bin": {
    "preflight": "./bin/preflight.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "docker-build": "docker build --tag preflight .",
    "docker-build-run": "pnpm docker-build && pnpm docker-run",
