    "execa": "9.6.1",
    "listr2": "10.2.2",
    "node-fetch": "3.3.2",
    "p-reduce": "3.0.0",
    "readdirp": "5.0.0",
    "semver": "7.8.5",
    "top-user-agents": "2.1.122"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/p-map": "2.0.0",
    "@types/semver": "7.7.1",
    "eslint": "10.7.0",
    "eslint-config-upleveled": "10.0.0",
    "p-map": "7.0.5",
